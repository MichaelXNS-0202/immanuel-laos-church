---
import { site, nav } from '../../site.config';
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={site.nameEnglish}>
      <span class="brand-mark">✝</span>
      <span class="brand-text">
        <span class="brand-name">{site.name}</span>
        <span class="brand-name-en">{site.nameEnglish}</span>
      </span>
    </a>

    <button class="nav-toggle" aria-label="ເປີດເມນູ" aria-expanded="false" aria-controls="primary-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" class="nav" aria-label="ເມນູຫຼັກ">
      <ul>
        {nav.map((item) => {
          const isActive = item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
          return (
            <li>
              <a href={item.href} aria-current={isActive ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(140%) blur(6px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.15rem;
    padding-bottom: 1.15rem;
    gap: 1.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    text-decoration: none;
  }
  .brand-mark {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    background: var(--ink);
    color: var(--bg);
    border-radius: 50%;
    font-size: 1.15rem;
    font-family: var(--font-display);
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
  }
  .brand-name-en {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .nav a {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
    border-radius: var(--radius);
    transition: color 150ms var(--ease), background 150ms var(--ease);
  }
  .nav a:hover { color: var(--ink); background: var(--bg-alt); }
  .nav a[aria-current="page"] {
    color: var(--accent-dark);
    font-weight: 600;
  }
  .nav a[aria-current="page"]::after {
    content: "";
    display: block;
    width: 18px;
    height: 2px;
    background: var(--accent);
    margin: 0.2rem auto 0;
  }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    border: 1px solid var(--line);
    background: var(--bg);
    border-radius: var(--radius);
    cursor: pointer;
    padding: 10px 8px;
    flex-direction: column;
    justify-content: space-between;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .nav {
      display: none;
      flex-basis: 100%;
      order: 3;
      margin-top: 0.75rem;
    }
    .nav.open { display: block; }
    .nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      border-top: 1px solid var(--line);
      padding-top: 0.5rem;
    }
    .nav a { padding: 0.75rem 0.5rem; }
    .nav a[aria-current="page"]::after { margin-left: 0; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const navEl = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = navEl?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
