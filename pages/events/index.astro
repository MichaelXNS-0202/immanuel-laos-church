---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const now = new Date();

const upcoming = allEvents
  .filter((e) => (e.data.endDate ?? e.data.date) >= now)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const past = allEvents
  .filter((e) => (e.data.endDate ?? e.data.date) < now)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('lo-LA', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
---

<BaseLayout title="ເຫດການ" description="ເຫດການ ແລະ ກິດຈະກຳຂອງໂບດ">
  <section class="section">
    <div class="container">
      <span class="eyebrow">ເຫດການ</span>
      <span class="hr-accent"></span>
      <h1>ເຫດການ ແລະ ກິດຈະກຳ</h1>
      <p style="max-width: 640px; color: var(--ink-soft); margin-bottom: 3rem;">
        ເບິ່ງກິດຈະກຳທີ່ກຳລັງຈະມີຂຶ້ນ ແລະ ເຫດການທີ່ຜ່ານມາ.
      </p>

      {upcoming.length > 0 && (
        <>
          <h2>ກຳລັງຈະມາເຖິງ</h2>
          <div class="events-list">
            {upcoming.map((ev) => (
              <article class="event-row">
                <div class="event-date">
                  <span class="event-day">
                    {ev.data.date.toLocaleDateString('lo-LA', { day: '2-digit' })}
                  </span>
                  <span class="event-month">
                    {ev.data.date.toLocaleDateString('lo-LA', { month: 'short' })}
                  </span>
                </div>
                <div class="event-body">
                  <h3>{ev.data.title}</h3>
                  <p class="event-meta">
                    {formatDate(ev.data.date)}
                    {ev.data.location && <> · <strong>{ev.data.location}</strong></>}
                  </p>
                  {ev.data.excerpt && <p>{ev.data.excerpt}</p>}
                </div>
              </article>
            ))}
          </div>
        </>
      )}

      {upcoming.length === 0 && (
        <p style="padding: 2rem; background: var(--bg-alt); border-radius: var(--radius); text-align: center;">
          ຍັງບໍ່ມີເຫດການທີ່ກຳລັງຈະມາເຖິງ. ກະລຸນາກວດເບິ່ງອີກຄັ້ງໃນພາຍຫຼັງ.
        </p>
      )}

      {past.length > 0 && (
        <>
          <hr class="hairline" style="margin: 4rem 0;" />
          <h2>ເຫດການທີ່ຜ່ານມາ</h2>
          <div class="events-list past">
            {past.slice(0, 6).map((ev) => (
              <article class="event-row">
                <div class="event-date">
                  <span class="event-day">
                    {ev.data.date.toLocaleDateString('lo-LA', { day: '2-digit' })}
                  </span>
                  <span class="event-month">
                    {ev.data.date.toLocaleDateString('lo-LA', { month: 'short' })}
                  </span>
                </div>
                <div class="event-body">
                  <h3>{ev.data.title}</h3>
                  <p class="event-meta">{formatDate(ev.data.date)}</p>
                </div>
              </article>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .events-list { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }

  .event-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1.75rem;
    padding: 1.5rem 1.75rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: transform 200ms var(--ease), box-shadow 200ms var(--ease);
  }
  .event-row:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -16px rgba(31, 42, 51, 0.18);
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0;
    background: var(--bg-alt);
    border-radius: var(--radius);
    border-left: 3px solid var(--accent);
  }
  .event-day {
    font-family: var(--font-display);
    font-size: 2.1rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }
  .event-month {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-top: 0.25rem;
  }

  .event-body h3 { margin-top: 0.25rem; margin-bottom: 0.4rem; }
  .event-meta {
    font-size: 0.92rem;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }
  .event-body p { color: var(--ink-soft); margin-bottom: 0; }

  .events-list.past { opacity: 0.8; }
  .events-list.past .event-date { border-left-color: var(--muted); }
  .events-list.past .event-month { color: var(--muted); }

  @media (max-width: 560px) {
    .event-row { grid-template-columns: 70px 1fr; gap: 1rem; padding: 1.25rem; }
    .event-day { font-size: 1.7rem; }
  }
</style>
